#!/usr/bin/env python
"""
Build Helm chart: install helm, run dependency build, package chart, emit launch layer + process.
Pure stdlib implementation for testability. Replaces the original shell script.
"""
from __future__ import annotations

import os
import platform
import re
import shutil
import stat
import subprocess
import sys
import tarfile
import urllib.request
from pathlib import Path


def get_env(name: str, default: str = "") -> str:
    return os.environ.get(name, default).strip()


def resolve_chart_path(build_dir: Path, chart_dir_env: str) -> Path:
    """Resolve chart root: directory that contains Chart.yaml."""
    if chart_dir_env:
        path = build_dir / chart_dir_env
        if (path / "Chart.yaml").is_file():
            return path
        raise SystemExitWithMessage(
            f"Chart.yaml not found at {path}",
            "Chart.yaml not found in BP_HELM_CHART_DIR path.",
        )
    for candidate in ("", "chart", "chartTemplate"):
        path = build_dir / candidate if candidate else build_dir
        if (path / "Chart.yaml").is_file():
            return path
    raise SystemExitWithMessage(
        f"Chart.yaml not found in {build_dir}, {build_dir}/chart, or {build_dir}/chartTemplate",
        "Set BP_HELM_CHART_DIR or use a supported layout (see docs/CHART-LAYOUT.md).",
    )


def parse_chart_yaml_field(chart_yaml_path: Path, key: str) -> str:
    """Parse first 'key: value' from Chart.yaml; trim quotes and whitespace."""
    value = ""
    prefix = key + ":"
    with open(chart_yaml_path, encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.rstrip("\r\n")
            if line.strip().startswith(prefix):
                value = line.split(prefix, 1)[1].strip().strip("'\"").strip()
                break
    return value


def chart_has_dependencies(chart_yaml_path: Path) -> bool:
    with open(chart_yaml_path, encoding="utf-8", errors="replace") as f:
        return "dependencies:" in f.read()


def validate_chart_layout(chart_path: Path) -> tuple[str, str]:
    """Validate layout and return (chart_name, chart_version). See docs/CHART-LAYOUT.md."""
    chart_yaml = chart_path / "Chart.yaml"
    if not chart_yaml.is_file():
        raise SystemExitWithMessage(
            f"Chart.yaml not found at {chart_path}",
            "See buildpack docs/CHART-LAYOUT.md.",
        )
    name = parse_chart_yaml_field(chart_yaml, "name")
    version = parse_chart_yaml_field(chart_yaml, "version")
    if not name:
        raise SystemExitWithMessage(
            f"Chart.yaml must contain 'name:' at chart root {chart_path}",
            "See buildpack docs/CHART-LAYOUT.md.",
        )
    if not version:
        raise SystemExitWithMessage(
            f"Chart.yaml must contain 'version:' at chart root {chart_path}",
            "See buildpack docs/CHART-LAYOUT.md.",
        )
    same_name_dir = chart_path / name
    if same_name_dir.is_dir():
        raise SystemExitWithMessage(
            f"Chart root must not contain a subdirectory named '{name}' (same as chart name).",
            f"Move Chart.yaml, values.yaml, templates/ to the chart root so there is no {name}/{name}/ nesting. "
            "See https://stackoverflow.com/questions/55605491 and buildpack docs/CHART-LAYOUT.md.",
        )
    return name, version


def install_helm(helm_layer: Path, helm_version: str) -> Path:
    """Install Helm into helm_layer/bin; return path to helm binary."""
    helm_bin_dir = helm_layer / "bin"
    helm_bin_dir.mkdir(parents=True, exist_ok=True)
    helm_binary = helm_bin_dir / "helm"
    if helm_binary.is_file() and os.access(helm_binary, os.X_OK):
        return helm_binary
    machine = platform.machine().lower()
    arch_map = {"x86_64": "amd64", "amd64": "amd64", "aarch64": "arm64", "arm64": "arm64"}
    helm_arch = arch_map.get(machine, "amd64")
    url = f"https://get.helm.sh/helm-v{helm_version}-linux-{helm_arch}.tar.gz"
    print("Installing Helm...", flush=True)
    with urllib.request.urlopen(url, timeout=60) as resp:
        with tarfile.open(fileobj=resp, mode="r:gz") as tar:
            tar.extractall(path=helm_layer)
    linux_dir = helm_layer / f"linux-{helm_arch}"
    extracted_helm = linux_dir / "helm"
    if extracted_helm.is_file():
        shutil.move(str(extracted_helm), str(helm_binary))
    shutil.rmtree(linux_dir, ignore_errors=True)
    helm_binary.chmod(helm_binary.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    return helm_binary


def run_helm(
    helm_bin: Path,
    args: list[str],
    cwd: Path | None = None,
    env: dict[str, str] | None = None,
    capture: bool = False,
) -> subprocess.CompletedProcess:
    env = env or os.environ.copy()
    path_prepend = str(helm_bin.parent)
    env["PATH"] = path_prepend + os.pathsep + env.get("PATH", "")
    cmd = [str(helm_bin)] + args
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=env,
        capture_output=capture,
        text=True,
        check=False,
    )


def write_helm_toml(layers_dir: Path) -> None:
    (layers_dir / "helm.toml").write_text(
        "[types]\nbuild = true\ncache = true\nlaunch = false\n",
        encoding="utf-8",
    )


def write_helm_chart_toml(layers_dir: Path) -> None:
    (layers_dir / "helm-chart.toml").write_text(
        "[types]\nlaunch = true\n",
        encoding="utf-8",
    )


def append_launch_toml(layers_dir: Path) -> None:
    launch = layers_dir / "launch.toml"
    content = (
        "[[processes]]\ntype = \"web\"\n"
        "command = [\"sh\", \"-c\", \"echo 'Helm chart OCI image. Chart at /layers/octopilot_helm/helm-chart/chart/*.tgz'; sleep infinity\"]\n"
        "default = true\n"
    )
    with open(launch, "a", encoding="utf-8") as f:
        f.write(content)


def package_chart(
    helm_bin: Path,
    chart_path: Path,
    chart_output_layer: Path,
) -> Path:
    """Run helm dependency build (if needed) and helm package. Return path to .tgz."""
    chart_out = chart_output_layer / "chart"
    chart_out.mkdir(parents=True, exist_ok=True)
    chart_yaml = chart_path / "Chart.yaml"
    if chart_yaml.is_file() and chart_has_dependencies(chart_yaml):
        print("Running helm dependency build...", flush=True)
        run_helm(helm_bin, ["dependency", "build", "."], cwd=chart_path)
    print("Packaging Helm chart...", flush=True)
    run_helm(
        helm_bin,
        ["package", ".", "--destination", str(chart_out)],
        cwd=chart_path,
    )
    tgz_files = list(chart_out.glob("*.tgz"))
    if not tgz_files:
        raise SystemExitWithMessage(
            "helm package did not produce a .tgz",
            "Check chart layout and Chart.yaml.",
        )
    chart_tgz = tgz_files[0]
    symlink = chart_out / "chart.tgz"
    if symlink.exists():
        symlink.unlink()
    symlink.symlink_to(chart_tgz.name)
    return chart_tgz


def extract_digest_from_push_output(push_output: str) -> str | None:
    match = re.search(r"sha256:[a-f0-9]+", push_output)
    return match.group(0) if match else None


def get_version_from_tgz(helm_bin: Path, chart_tgz: Path) -> str:
    result = run_helm(helm_bin, ["show", "chart", str(chart_tgz)], capture=True)
    if result.returncode != 0:
        return ""
    for line in result.stdout.splitlines():
        line = line.strip()
        if line.startswith("version:"):
            return line.split(":", 1)[1].strip().strip("'\"")
    return ""


def oci_push(
    helm_bin: Path,
    chart_tgz: Path,
    oci_ref: str,
    out_dir: Path,
    plain_http: bool,
) -> None:
    """Push chart to OCI, write ref/digest to out_dir."""
    out_dir.mkdir(parents=True, exist_ok=True)
    args = [str(chart_tgz), f"oci://{oci_ref}"]
    if plain_http:
        args.append("--plain-http")
    result = run_helm(helm_bin, ["push"] + args, capture=True)
    push_output = (result.stdout or "") + (result.stderr or "")
    print(push_output, flush=True)
    if result.returncode != 0:
        if out_dir.is_dir():
            try:
                (out_dir / "push-failed").write_text(
                    f"helm push failed: {push_output or 'unknown'}",
                    encoding="utf-8",
                )
            except OSError:
                pass
        raise SystemExitWithMessage("helm push failed", push_output or "unknown")
    digest = extract_digest_from_push_output(push_output)
    if not digest:
        raise SystemExitWithMessage(
            "Could not extract digest from helm push output (platform needs ref with digest for Flux)",
            push_output,
        )
    chart_version = get_version_from_tgz(helm_bin, chart_tgz) or "0.0.0"
    full_ref = f"{oci_ref}:{chart_version}@{digest}"
    print(f"Pushed: {full_ref}", flush=True)
    if not out_dir.is_dir():
        raise SystemExitWithMessage(
            f"BP_HELM_OCI_OUTPUT {out_dir} is not a writable directory (ref/digest not written)",
            "Ensure the volume mount is writable.",
        )
    try:
        try:
            out_dir.chmod(stat.S_IRWXU | stat.S_IRWXG | stat.S_IRWXO)
        except OSError:
            pass
        (out_dir / "digest").write_text(digest, encoding="utf-8")
        (out_dir / "ref").write_text(full_ref, encoding="utf-8")
        shutil.copy2(chart_tgz, out_dir / "chart.tgz")
    except OSError as e:
        raise SystemExitWithMessage(
            f"BP_HELM_OCI_OUTPUT {out_dir} is not a writable directory (ref/digest not written)",
            str(e),
        )


class SystemExitWithMessage(SystemExit):
    """Exit with code 1 and print message to stderr."""

    def __init__(self, message: str, extra: str = "") -> None:
        self.message = message
        self.extra = extra
        super().__init__(1)

    def emit(self) -> None:
        print(f"ERROR: {self.message}", file=sys.stderr)
        if self.extra:
            print(self.extra, file=sys.stderr)


def main() -> None:
    build_dir = Path(get_env("CNB_BUILD_DIR", "/workspace"))
    layers_dir = Path(get_env("CNB_LAYERS_DIR", "/layers"))
    chart_dir_env = get_env("BP_HELM_CHART_DIR")
    helm_version = get_env("BP_HELM_VERSION", "3.16.4")
    oci_ref = get_env("BP_HELM_OCI_REF")
    oci_output = get_env("BP_HELM_OCI_OUTPUT", "/out")
    plain_http_val = get_env("BP_HELM_OCI_PLAIN_HTTP").lower()
    plain_http = plain_http_val not in ("", "0", "false")

    try:
        if not build_dir.is_dir():
            raise SystemExitWithMessage(
                f"CNB_BUILD_DIR ({build_dir}) is not a directory",
                "Set CNB_BUILD_DIR to the build context path.",
            )
    except SystemExitWithMessage as e:
        e.emit()
        sys.exit(e.args[0])

    print("Octopilot Helm Buildpack", flush=True)

    try:
        chart_path = resolve_chart_path(build_dir, chart_dir_env)
    except SystemExitWithMessage as e:
        e.emit()
        sys.exit(1)

    if not (chart_path / "Chart.yaml").is_file():
        print(f"Chart.yaml not found at {chart_path}", file=sys.stderr)
        sys.exit(1)

    try:
        chart_name, chart_version = validate_chart_layout(chart_path)
    except SystemExitWithMessage as e:
        e.emit()
        sys.exit(1)

    print(f"Chart layout OK (name={chart_name} version={chart_version})", flush=True)

    helm_layer = layers_dir / "helm"
    try:
        helm_bin = install_helm(helm_layer, helm_version)
    except (OSError, urllib.error.URLError, KeyError) as e:
        print(f"ERROR: Failed to install Helm: {e}", file=sys.stderr)
        sys.exit(1)

    write_helm_toml(layers_dir)
    chart_output_layer = layers_dir / "helm-chart"
    try:
        chart_tgz = package_chart(helm_bin, chart_path, chart_output_layer)
    except SystemExitWithMessage as e:
        e.emit()
        sys.exit(1)

    write_helm_chart_toml(layers_dir)
    append_launch_toml(layers_dir)

    print(
        f"BP_HELM_OCI_REF={oci_ref or '<unset>'} BP_HELM_OCI_OUTPUT={oci_output or '<unset>'} "
        f"BP_HELM_OCI_PLAIN_HTTP={get_env('BP_HELM_OCI_PLAIN_HTTP') or '<unset>'}",
        flush=True,
    )
    if oci_ref:
        print("Pushing Helm chart to OCI (BP_HELM_OCI_REF) for Flux/helm OCI format...", flush=True)
        out_path = Path(oci_output)
        try:
            oci_push(helm_bin, chart_tgz, oci_ref, out_path, plain_http)
        except SystemExitWithMessage as e:
            e.emit()
            sys.exit(1)

    print("Helm build complete: chart packaged into launch layer", flush=True)


if __name__ == "__main__":
    main()
