#!/bin/sh
# Build Helm chart: install helm, dependency build, package, optional OCI push.
# Same behaviour as bin/build.python. Pure shell for builders without Python.
set -e

get_env() {
  _v=$(eval "echo \${$1:-}")
  echo "$_v" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

err_exit() {
  echo "ERROR: $1" >&2
  [ -n "$2" ] && echo "$2" >&2
  exit 1
}

BUILD_DIR="${CNB_BUILD_DIR:-/workspace}"
LAYERS_DIR="${CNB_LAYERS_DIR:-/layers}"
CHART_DIR_ENV=$(get_env BP_HELM_CHART_DIR)
HELM_VERSION=$(get_env BP_HELM_VERSION)
: "${HELM_VERSION:=3.16.4}"
OCI_REF=$(get_env BP_HELM_OCI_REF)
OCI_OUTPUT=$(get_env BP_HELM_OCI_OUTPUT)
: "${OCI_OUTPUT:=/out}"
PLAIN_HTTP_VAL=$(get_env BP_HELM_OCI_PLAIN_HTTP)

# Resolve plain_http: 1/true/yes -> true, 0/false -> false, else unset (detect later)
PLAIN_HTTP=""
case "$PLAIN_HTTP_VAL" in
  1|true|yes) PLAIN_HTTP=1 ;;
  0|false)    PLAIN_HTTP=0 ;;
esac

if [ ! -d "$BUILD_DIR" ]; then
  err_exit "CNB_BUILD_DIR ($BUILD_DIR) is not a directory" "Set CNB_BUILD_DIR to the build context path."
fi

echo "Octopilot Helm Buildpack"

# Resolve chart path
resolve_chart_path() {
  if [ -n "$CHART_DIR_ENV" ]; then
    p="$BUILD_DIR/$CHART_DIR_ENV"
    [ -f "$p/Chart.yaml" ] || err_exit "Chart.yaml not found at $p" "Chart.yaml not found in BP_HELM_CHART_DIR path."
    echo "$p"
    return
  fi
  for c in "" "chart" "chartTemplate"; do
    if [ -z "$c" ]; then p="$BUILD_DIR"; else p="$BUILD_DIR/$c"; fi
    [ -f "$p/Chart.yaml" ] && echo "$p" && return
  done
  err_exit "Chart.yaml not found in $BUILD_DIR, $BUILD_DIR/chart, or $BUILD_DIR/chartTemplate" \
    "Set BP_HELM_CHART_DIR or use a supported layout (see docs/CHART-LAYOUT.md)."
}

CHART_PATH=$(resolve_chart_path)
CHART_YAML="$CHART_PATH/Chart.yaml"
[ -f "$CHART_YAML" ] || err_exit "Chart.yaml not found at $CHART_PATH"

# Parse Chart.yaml field (first key: value)
parse_field() {
  _key="$1"
  grep -E "^[[:space:]]*${_key}[[:space:]]*:" "$CHART_YAML" | head -1 | sed "s/.*${_key}[[:space:]]*:[[:space:]]*//;s/^[\"']//;s/[\"']$//;s/^[[:space:]]*//;s/[[:space:]]*$//"
}

CHART_NAME=$(parse_field name)
CHART_VERSION=$(parse_field version)
[ -n "$CHART_NAME" ] || err_exit "Chart.yaml must contain 'name:' at chart root $CHART_PATH" "See buildpack docs/CHART-LAYOUT.md."
[ -n "$CHART_VERSION" ] || err_exit "Chart.yaml must contain 'version:' at chart root $CHART_PATH" "See buildpack docs/CHART-LAYOUT.md."
[ ! -d "$CHART_PATH/$CHART_NAME" ] || err_exit "Chart root must not contain a subdirectory named '$CHART_NAME' (same as chart name)." \
  "Move Chart.yaml, values.yaml, templates/ to the chart root. See buildpack docs/CHART-LAYOUT.md."

echo "Chart layout OK (name=$CHART_NAME version=$CHART_VERSION)"

# Install Helm: use system if on PATH, else download
HELM_LAYER="$LAYERS_DIR/helm"
HELM_BIN=""
if command -v helm >/dev/null 2>&1; then
  HELM_BIN=$(command -v helm)
  echo "Using Helm from PATH"
else
  HELM_BIN_DIR="$HELM_LAYER/bin"
  mkdir -p "$HELM_BIN_DIR"
  HELM_BIN="$HELM_BIN_DIR/helm"
  if [ -x "$HELM_BIN" ]; then
    : # already installed
  else
    echo "Installing Helm..."
    _arch=$(uname -m)
    case "$_arch" in
      x86_64|amd64) helm_arch=amd64 ;;
      aarch64|arm64) helm_arch=arm64 ;;
      *) helm_arch=amd64 ;;
    esac
    _os=$(uname -s | tr '[:upper:]' '[:lower:]')
    case "$_os" in
      linux|darwin) ;;
      *) _os=linux ;;
    esac
    _url="https://get.helm.sh/helm-v${HELM_VERSION}-${_os}-${helm_arch}.tar.gz"
    _insecure=$(get_env BP_HELM_DOWNLOAD_INSECURE)
    _curl_extra=""
    case "$_insecure" in
      1|true|yes) _curl_extra="-k" ;;
    esac
    if ! (cd "$HELM_LAYER" && curl -sSLf $_curl_extra --connect-timeout 60 -o - "$_url" | tar -xzf -); then
      err_exit "Failed to download or extract Helm from $_url"
    fi
    _extracted="$HELM_LAYER/${_os}-${helm_arch}"
    [ -f "$_extracted/helm" ] && mv "$_extracted/helm" "$HELM_BIN"
    rm -rf "$_extracted"
    chmod +x "$HELM_BIN"
  fi
fi

# Layer tomls
printf '%s\n' '[types]' 'build = true' 'cache = true' 'launch = false' > "$LAYERS_DIR/helm.toml"
printf '%s\n' '[types]' 'launch = true' > "$LAYERS_DIR/helm-chart.toml"
printf '%s\n' '[[processes]]' 'type = "web"' 'command = ["sh", "-c", "echo '\''Helm chart OCI image. Chart at /layers/octopilot_helm/helm-chart/chart/*.tgz'\''; sleep infinity"]' 'default = true' >> "$LAYERS_DIR/launch.toml"

# Package chart
CHART_OUT_LAYER="$LAYERS_DIR/helm-chart"
CHART_OUT="$CHART_OUT_LAYER/chart"
mkdir -p "$CHART_OUT"

_has_deps=0
grep -q "dependencies:" "$CHART_YAML" 2>/dev/null && _has_deps=1
if [ "$_has_deps" = 1 ]; then
  echo "Running helm dependency build..."
  (cd "$CHART_PATH" && "$HELM_BIN" dependency build .) || err_exit "helm dependency build failed"
fi

echo "Packaging Helm chart..."
(cd "$CHART_PATH" && "$HELM_BIN" package . --destination "$CHART_OUT") || err_exit "helm package failed"

_tgz=$(find "$CHART_OUT" -maxdepth 1 -name '*.tgz' -print -quit)
[ -n "$_tgz" ] && [ -f "$_tgz" ] || err_exit "helm package did not produce a .tgz" "Check chart layout and Chart.yaml."

rm -f "$CHART_OUT/chart.tgz"
ln -s "$(basename "$_tgz")" "$CHART_OUT/chart.tgz"

echo "BP_HELM_OCI_REF=${OCI_REF:-<unset>} BP_HELM_OCI_OUTPUT=${OCI_OUTPUT:-<unset>} BP_HELM_OCI_PLAIN_HTTP=${PLAIN_HTTP_VAL:-<unset>}"

# OCI push if BP_HELM_OCI_REF set
if [ -n "$OCI_REF" ]; then
  # Resolve plain_http: detect scheme if not explicitly set
  _plain_http="$PLAIN_HTTP"
  if [ -z "$_plain_http" ]; then
    _host=$(echo "$OCI_REF" | cut -d/ -f1)
    [ -z "$_host" ] && _host="localhost:5000"
    _code=""
    _code=$(curl -sSf -o /dev/null -w "%{http_code}" --connect-timeout 5 "https://${_host}/v2/" 2>/dev/null) || true
    if [ "$_code" = "200" ] || [ "$_code" = "401" ]; then
      echo "Registry scheme: HTTPS (valid cert)"
      _plain_http=0
    else
      _code=$(curl -sSf -k -o /dev/null -w "%{http_code}" --connect-timeout 5 "https://${_host}/v2/" 2>/dev/null) || true
      if [ "$_code" = "200" ] || [ "$_code" = "401" ]; then
        echo "Registry scheme: HTTPS (self-signed/insecure)"
        _plain_http=0
      else
        _code=$(curl -sSf -o /dev/null -w "%{http_code}" --connect-timeout 5 "http://${_host}/v2/" 2>/dev/null) || true
        if [ "$_code" = "200" ] || [ "$_code" = "401" ]; then
          echo "Registry scheme: HTTP (fallback)"
          _plain_http=1
        else
          echo "Registry scheme: HTTP (default, probe failed)"
          _plain_http=1
        fi
      fi
    fi
  fi

  echo "Pushing Helm chart to OCI (BP_HELM_OCI_REF) for Flux/helm OCI format..."
  mkdir -p "$OCI_OUTPUT"
  if [ "$_plain_http" = "1" ]; then
    _push_out=$("$HELM_BIN" push "$_tgz" "oci://$OCI_REF" --plain-http 2>&1); _rc=$?
  else
    _push_out=$("$HELM_BIN" push "$_tgz" "oci://$OCI_REF" 2>&1); _rc=$?
  fi
  echo "$_push_out"
  if [ $_rc -ne 0 ] || ! echo "$_push_out" | grep -qE 'sha256:[a-f0-9]+'; then
    echo "helm push failed: $_push_out" > "$OCI_OUTPUT/push-failed" 2>/dev/null || true
    err_exit "helm push failed" "$_push_out"
  fi
  _digest=$(echo "$_push_out" | grep -oE 'sha256:[a-f0-9]+' | head -1)
  [ -n "$_digest" ] || err_exit "Could not extract digest from helm push output" "$_push_out"
  _ver=$("$HELM_BIN" show chart "$_tgz" 2>/dev/null | grep -E '^version:' | sed "s/version:[[:space:]]*//;s/[\"']//g" | tr -d ' \t' || echo "0.0.0")
  _full_ref="${OCI_REF}:${_ver}@${_digest}"
  echo "Pushed: $_full_ref"
  echo "$_digest" > "$OCI_OUTPUT/digest"
  echo "$_full_ref" > "$OCI_OUTPUT/ref"
  cp "$_tgz" "$OCI_OUTPUT/chart.tgz" 2>/dev/null || err_exit "BP_HELM_OCI_OUTPUT $OCI_OUTPUT is not a writable directory" "Ensure the volume mount is writable."
fi

echo "Helm build complete: chart packaged into launch layer"
