#!/bin/bash
# Build Helm chart: install helm, run dependency build, package chart, emit launch layer + process.
set -ex

BUILD_DIR="${CNB_BUILD_DIR:-/workspace}"
LAYERS_DIR="${CNB_LAYERS_DIR:-/layers}"
PLAN_PATH="${CNB_PLAN_PATH:-/dev/null}"

if [[ ! -d "${BUILD_DIR}" ]]; then
  echo "CNB_BUILD_DIR (${BUILD_DIR}) is not a directory" >&2
  exit 1
fi

echo "Octopilot Helm Buildpack"

# Resolve chart root: the directory that contains Chart.yaml (and values.yaml, templates/, etc.).
# Same as "helm package ./chartTemplate" we must package the whole chart directory, not
# just templates/ or a subdirectory.
CHART_DIR="${BP_HELM_CHART_DIR:-}"
if [[ -n "${CHART_DIR}" ]]; then
  CHART_PATH="${BUILD_DIR}/${CHART_DIR}"
else
  if [[ -f "${BUILD_DIR}/Chart.yaml" ]]; then
    CHART_PATH="${BUILD_DIR}"
  elif [[ -f "${BUILD_DIR}/chart/Chart.yaml" ]]; then
    CHART_PATH="${BUILD_DIR}/chart"
  else
    echo "Chart.yaml not found in ${BUILD_DIR} or ${BUILD_DIR}/chart" >&2
    exit 1
  fi
fi

if [[ ! -f "${CHART_PATH}/Chart.yaml" ]]; then
  echo "Chart.yaml not found at ${CHART_PATH}" >&2
  exit 1
fi

# Install Helm into a build+cache layer (reused)
HELM_LAYER="${LAYERS_DIR}/helm"
HELM_BIN="${HELM_LAYER}/bin"
export PATH="${HELM_BIN}:${PATH}"

if [[ ! -x "${HELM_BIN}/helm" ]]; then
  echo "Installing Helm..."
  mkdir -p "${HELM_BIN}"
  HELM_VER="${BP_HELM_VERSION:-3.16.4}"
  ARCH=$(uname -m)
  case "${ARCH}" in
    x86_64|amd64) HELM_ARCH="amd64" ;;
    aarch64|arm64) HELM_ARCH="arm64" ;;
    *) HELM_ARCH="amd64" ;;
  esac
  curl -sSL "https://get.helm.sh/helm-v${HELM_VER}-linux-${HELM_ARCH}.tar.gz" | tar -xzf - -C "${HELM_LAYER}"
  mv "${HELM_LAYER}/linux-${HELM_ARCH}/helm" "${HELM_BIN}/helm"
  rm -rf "${HELM_LAYER}/linux-${HELM_ARCH}"
  chmod +x "${HELM_BIN}/helm"
fi

# Mark helm as build+cache only (not in run image)
cat > "${LAYERS_DIR}/helm.toml" << 'TOML'
[types]
build = true
cache = true
launch = false
TOML

# Output layer: packaged chart (launch = true so it's in the run image)
CHART_OUTPUT_LAYER="${LAYERS_DIR}/helm-chart"
mkdir -p "${CHART_OUTPUT_LAYER}/chart"

# helm dependency build (if Chart.yaml has dependencies)
cd "${CHART_PATH}"
if [[ -f "Chart.yaml" ]] && grep -q "dependencies:" Chart.yaml 2>/dev/null; then
  echo "Running helm dependency build..."
  helm dependency build . 2>/dev/null || true
fi

# Package the whole chart directory (Chart.yaml, values.yaml, templates/, etc.) — same as
# helm package ./chartTemplate in sam; do not package only a subdirectory.
echo "Packaging Helm chart..."
helm package . --destination "${CHART_OUTPUT_LAYER}/chart"

# Chart name is <name>-<version>.tgz from helm package
CHART_TGZ=$(find "${CHART_OUTPUT_LAYER}/chart" -maxdepth 1 -name "*.tgz" | head -1)
if [[ -z "${CHART_TGZ}" || ! -f "${CHART_TGZ}" ]]; then
  echo "helm package did not produce a .tgz" >&2
  exit 1
fi

# Canonical name for consumers (e.g. helm pull oci://... or copy from image)
ln -sf "$(basename "${CHART_TGZ}")" "${CHART_OUTPUT_LAYER}/chart/chart.tgz" 2>/dev/null || true

# This layer is included in the run image
cat > "${LAYERS_DIR}/helm-chart.toml" << 'TOML'
[types]
launch = true
TOML

# Process: keep container alive so image can be pushed as OCI; chart is at /layers/octopilot_helm/helm-chart/chart/
cat >> "${LAYERS_DIR}/launch.toml" << 'LAUNCH'
[[processes]]
type = "web"
command = ["sh", "-c", "echo 'Helm chart OCI image. Chart at /layers/octopilot_helm/helm-chart/chart/*.tgz'; sleep infinity"]
default = true
LAUNCH

# When BP_HELM_OCI_REF is set, push the chart with helm push so the registry gets a proper
# Helm OCI artifact (layer media type application/vnd.cncf.helm.chart.content.v1.tar+gzip).
# Flux OCIRepository and "helm install oci://..." require this format; the lifecycle's
# container image export uses generic layer types and cannot be used as a Helm chart.
# The platform (e.g. op) should set BP_HELM_OCI_REF (e.g. ttl.sh/<uuid>-chart) and
# run pack build with --publish false so the buildpack's helm push is the only push.
echo "BP_HELM_OCI_REF=${BP_HELM_OCI_REF:-<unset>} BP_HELM_OCI_OUTPUT=${BP_HELM_OCI_OUTPUT:-<unset>} BP_HELM_OCI_PLAIN_HTTP=${BP_HELM_OCI_PLAIN_HTTP:-<unset>}"
if [[ -n "${BP_HELM_OCI_REF:-}" ]]; then
  echo "Pushing Helm chart to OCI (BP_HELM_OCI_REF) for Flux/helm OCI format..."
  OUT_DIR="${BP_HELM_OCI_OUTPUT:-/out}"
  mkdir -p "${OUT_DIR}" 2>/dev/null || true
  PUSH_ARGS=("${CHART_TGZ}" "oci://${BP_HELM_OCI_REF}")
  [[ -n "${BP_HELM_OCI_PLAIN_HTTP:-}" ]] && [[ "${BP_HELM_OCI_PLAIN_HTTP}" != "0" ]] && [[ "${BP_HELM_OCI_PLAIN_HTTP}" != "false" ]] && PUSH_ARGS+=(--plain-http)
  PUSH_OUTPUT="$(helm push "${PUSH_ARGS[@]}" 2>&1)" || PUSH_FAILED=1
  echo "$PUSH_OUTPUT"
  if [[ -n "${PUSH_FAILED:-}" ]]; then
    if [[ -n "${BP_HELM_OCI_OUTPUT:-}" ]] && [[ -d "${OUT_DIR}" ]] && [[ -w "${OUT_DIR}" ]]; then
      echo "helm push failed: ${PUSH_OUTPUT:-unknown}" > "${OUT_DIR}/push-failed"
    fi
    exit 1
  fi
  DIGEST="$(echo "$PUSH_OUTPUT" | grep -oE 'sha256:[a-f0-9]+' | head -1)"
  if [[ -z "${DIGEST}" ]]; then
    echo "ERROR: could not extract digest from helm push output (platform needs ref with digest for Flux)" >&2
    echo "$PUSH_OUTPUT" >&2
    exit 1
  fi
  CHART_VERSION="$(helm show chart "$CHART_TGZ" | grep '^version:' | awk '{print $2}')"
  # Full ref for platform to use in build_result.json (same as sam: repo:version@digest)
  FULL_REF="${BP_HELM_OCI_REF}:${CHART_VERSION}@${DIGEST}"
  echo "Pushed: ${FULL_REF}"
  if [[ -n "${BP_HELM_OCI_OUTPUT:-}" ]]; then
    # When build runs as root (e.g. in builder), ensure mount is writable so we can write ref/digest
    if [[ -d "${OUT_DIR}" ]]; then
      chmod 766 "${OUT_DIR}" 2>/dev/null || true
    fi
    if [[ ! -d "${OUT_DIR}" ]] || [[ ! -w "${OUT_DIR}" ]]; then
      echo "ERROR: BP_HELM_OCI_OUTPUT ${BP_HELM_OCI_OUTPUT} is not a writable directory (ref/digest not written)" >&2
      exit 1
    fi
    echo "${DIGEST}" > "${OUT_DIR}/digest"
    echo "${FULL_REF}" > "${OUT_DIR}/ref"
    cp "${CHART_TGZ}" "${OUT_DIR}/chart.tgz" 2>/dev/null || true
  fi
fi

echo "Helm build complete: chart packaged into launch layer"
