#!/bin/sh
# Detect Helm chart: Chart.yaml in build dir or in chart/ subdir (or BP_HELM_CHART_DIR).
# Same behaviour as bin/detect.python. Exit 0 if chart found, 100 if not.
set -e

BUILD_DIR="${CNB_BUILD_DIR:-.}"
CHART_DIR_ENV="${BP_HELM_CHART_DIR:-}"

if [ -n "$CHART_DIR_ENV" ]; then
  [ -f "$BUILD_DIR/$CHART_DIR_ENV/Chart.yaml" ] && exit 0
else
  [ -f "$BUILD_DIR/Chart.yaml" ] && exit 0
  [ -f "$BUILD_DIR/chart/Chart.yaml" ] && exit 0
fi
exit 100
